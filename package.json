{
  "name": "niet-unified-erp",
  "version": "0.1.0",
  "private": true,
  "description": "On-premise NIET Unified ERP platform",
  "engines": {
    "node": ">=24 <25"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:api": "npm run start:dev --workspace @niet/api",
    "db:migrate": "node scripts/migrate.mjs",
    "db:verify": "node scripts/verify-database.mjs",
    "access:bootstrap": "node scripts/bootstrap-access.mjs",
    "access:verify": "node scripts/verify-access.mjs",
    "workflow:verify": "node scripts/verify-workflow.mjs",
    "documents:verify": "node scripts/verify-documents.mjs",
    "object-storage:verify": "node scripts/verify-object-storage.mjs",
    "notifications:verify": "node scripts/verify-notifications.mjs",
    "outbox:verify": "node scripts/verify-outbox.mjs",
    "search:verify": "node scripts/verify-search.mjs",
    "restore:verify": "node scripts/verify-restore.mjs",
    "load:verify": "node scripts/verify-load.mjs",
    "platform-slice:verify": "node scripts/verify-platform-slice.mjs",
    "failure:verify": "sh scripts/verify-dependency-failure.sh",
    "contract:verify": "node scripts/verify-api-contract.mjs",
    "oidc:verify": "node scripts/verify-oidc.mjs",
    "students:verify": "node scripts/verify-students.mjs",
    "curriculum:verify": "node scripts/verify-curriculum.mjs",
    "registration:verify": "node scripts/verify-registration.mjs",
    "attendance:verify": "node scripts/verify-attendance.mjs",
    "finance:verify": "node scripts/verify-finance.mjs",
    "fee-structures:verify": "node scripts/verify-fee-structures.mjs",
    "migration:verify": "node scripts/verify-migration.mjs",
    "admissions:verify": "node scripts/verify-admissions.mjs",
    "admission-offers:verify": "node scripts/verify-admission-offers.mjs",
    "seat-matrices:verify": "node scripts/verify-seat-matrices.mjs",
    "admission-cancellations:verify": "node scripts/verify-admission-cancellations.mjs",
    "timetable:verify": "node scripts/verify-timetable.mjs",
    "student-core:verify": "node scripts/verify-student-core.mjs",
    "programmes:verify": "node scripts/verify-programmes.mjs",
    "holds:verify": "node scripts/verify-holds.mjs",
    "student-withdrawals:verify": "node scripts/verify-student-withdrawals.mjs",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "verify": "npm run typecheck && npm run lint && npm test && npm run build"
  }
}
