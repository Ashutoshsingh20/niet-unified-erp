NODE_ENV=development
PORT=3001
HOST=127.0.0.1
LOG_LEVEL=info
TRUST_PROXY=false
DATABASE_URL=postgresql://niet_erp:niet_erp_dev@127.0.0.1:5432/niet_erp
OIDC_ISSUER=http://127.0.0.1:8080/realms/niet
OIDC_AUDIENCE=niet-erp-api
OIDC_JWKS_URI=http://127.0.0.1:8080/realms/niet/protocol/openid-connect/certs
OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ACCESS_KEY=replace-with-development-access-key
OBJECT_STORAGE_SECRET_KEY=replace-with-development-secret-key
OBJECT_STORAGE_QUARANTINE_BUCKET=niet-erp-quarantine
OBJECT_STORAGE_CLEAN_BUCKET=niet-erp-documents
NIET_API_BASE_URL=http://127.0.0.1:3001/api
WEB_ORIGIN=http://127.0.0.1:3000
OIDC_CLIENT_ID=niet-erp-web
OIDC_CLIENT_SECRET=replace-with-keycloak-client-secret
OIDC_REDIRECT_URI=http://127.0.0.1:3000/auth/callback
SESSION_ENCRYPTION_KEY=replace-with-base64url-encoded-32-byte-random-secret
